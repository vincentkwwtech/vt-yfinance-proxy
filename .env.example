# ===== 代理配置 =====
# 是否启用代理（true/false）
USE_PROXY=false

# 代理地址（仅 USE_PROXY=true 时生效）
# 支持 HTTP / HTTPS / SOCKS5
# YFINANCE_PROXY=http://proxy.example.com:8080
# YFINANCE_PROXY=https://proxy.example.com:8443
# YFINANCE_PROXY=socks5://proxy.example.com:1080

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
